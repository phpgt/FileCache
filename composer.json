{
	"name": "phpgt/filecache",
	"description": " Cache data in local files.",
	"type": "library",

	"require": {
		"php": ">=8.1",
		"phpgt/typesafegetter": "^v1.2.4"
	},

	"require-dev": {
		"phpstan/phpstan": "^1.10 || ^2.0",
		"phpunit/phpunit": "^10.1",
		"phpmd/phpmd": "^2.13",
		"squizlabs/php_codesniffer": "^3.7 || ^4.0"
	},

	"scripts": {
		"phpunit": "vendor/bin/phpunit --configuration phpunit.xml",
		"phpunit:coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --configuration phpunit.xml --coverage-text",
		"phpstan": "vendor/bin/phpstan analyse --level 6 src --memory-limit 256M",
		"phpcs": "vendor/bin/phpcs src --standard=phpcs.xml",
		"phpmd": "vendor/bin/phpmd src/ text phpmd.xml",
		"test": [
			"@phpunit",
			"@phpstan",
			"@phpcs",
			"@phpmd"
		]
	},

	"license": "MIT",
	"authors": [
		{
			"name": "Greg Bowler",
			"homepage": "https://www.g105b.com",
			"email": "greg.bowler@g105b.com",
			"role": "Developer"
		}
	],

	"autoload": {
		"psr-4": {
			"Gt\\FileCache\\": "./src"
		}
	},

	"autoload-dev": {
		"psr-4": {
			"Gt\\FileCache\\Test\\": "./test/phpunit"
		}
	},

	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/PhpGt"
		}
	]
}
